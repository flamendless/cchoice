		case enums.BRAND_STATUS_ACTIVE:
			<span class="text-green-600 font-medium">{ status.String() }</span>
		case enums.BRAND_STATUS_DELETED:
			<span class="text-red-600 font-medium">{ status.String() }</span>
		default:
			<span class="text-gray-600">{ status.String() }</span>
	}
}

templ BrandActionPublish(brandID string) {
	<button
		class="text-white bg-green-600 hover:bg-green-700 px-3 py-1 rounded text-xs font-medium"
		hx-patch={ utils.URLf("/admin/brands/%s/status", brandID) }
		hx-vals={ `{"status": "ACTIVE"}` }
		hx-swap="none"
	>
		Publish
	</button>
}

templ BrandActionDraft(brandID string) {
	<button
		class="text-white bg-yellow-600 hover:bg-yellow-700 px-3 py-1 rounded text-xs font-medium"
		hx-patch={ utils.URLf("/admin/brands/%s/status", brandID) }
		hx-vals={ `{"status": "DRAFT"}` }
		hx-swap="none"
	>
		Draft
	</button>
}

templ WeightUnitDropdown(selected enums.WeightUnit) {
	<select
		id="spec_weight_unit"
		name="spec_weight_unit"
		required
		class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-primary focus:border-primary"
	>
		<option value="">Select unit</option>
		for _, wu := range enums.AllWeightUnits {
			{{ v := wu.String() }}
			<option
				value={ v }
				selected?={ selected == wu }
			>
				{ v }
			</option>
		}
	</select>
}

templ StocksInDropdown(selected enums.StocksIn) {
	<select
		id="stocks_in"
		name="stocks_in"
		required
		class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-primary focus:border-primary"
	>
		<option value="">Select</option>
		for _, si := range enums.AllStocksIn {
			{{ v := si.String() }}
			<option
				value={ v }
				selected?={ selected == si }
			>
				{ v }
			</option>
		}
	</select>
}

templ TablePaginationBar(p models.TablePagination) {
	<div class="flex flex-wrap justify-center items-center gap-4 py-3">
		<span class="text-sm text-gray-600">
			if p.TotalCount == 0 {
				Showing 0 of 0
			} else {
				Showing { fmt.Sprintf("%d", p.StartItem()) }–{ fmt.Sprintf("%d", p.EndItem()) } of { fmt.Sprintf("%d", p.TotalCount) }
			}
		</span>
		<div class="flex items-center gap-2">
			if p.HasPrev() {
				<button
					type="button"
					class="px-3 py-1 text-sm border border-gray-300 rounded-md hover:bg-gray-50 text-gray-700"
					hx-get={ p.TableURL }
					hx-include={ p.Include }
					hx-vals={ fmt.Sprintf(`{"page": "%d"}`, p.Page-1) }
					hx-target={ p.ContentTarget }
					hx-swap="innerHTML"
				>
					Previous
				</button>
			} else {
				<button
					type="button"
					class="px-3 py-1 text-sm border border-gray-200 rounded-md text-gray-400 cursor-not-allowed"
					disabled
				>
					Previous
				</button>
			}
			<span class="text-sm text-gray-700">
				Page { fmt.Sprintf("%d", p.Page) } of { fmt.Sprintf("%d", p.TotalPages()) }
			</span>
			if p.HasNext() {
				<button
					type="button"
					class="px-3 py-1 text-sm border border-gray-300 rounded-md hover:bg-gray-50 text-gray-700"
					hx-get={ p.TableURL }
					hx-include={ p.Include }
					hx-vals={ fmt.Sprintf(`{"page": "%d"}`, p.Page+1) }
					hx-target={ p.ContentTarget }
					hx-swap="innerHTML"
				>
					Next
				</button>
			} else {
				<button
					type="button"
					class="px-3 py-1 text-sm border border-gray-200 rounded-md text-gray-400 cursor-not-allowed"
					disabled
				>
					Next
				</button>
			}
		</div>
	</div>
}
