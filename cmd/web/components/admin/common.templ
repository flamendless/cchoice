}

templ ProductActionDraft(productID string) {
	<button
		class="text-white bg-yellow-600 hover:bg-yellow-700 px-3 py-1 rounded text-xs font-medium"
		hx-patch={ utils.URL(fmt.Sprintf("/admin/superuser/products/%s/status", productID)) }
		hx-vals={ `{"status": "DRAFT"}` }
