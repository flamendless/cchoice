		class="text-white bg-green-600 hover:bg-green-700 px-3 py-1 rounded text-xs font-medium"
		hx-patch={ utils.URL(fmt.Sprintf("/admin/superuser/products/%s/status", productID)) }
		hx-vals={ `{"status": "ACTIVE"}` }
	>
		Publish
	</button>
}

templ ProductActionEditTo(productID string, basePath string) {
